# ── ThreatLens Configuration ────────────────────────────────────────────────

# Admin panel credentials (CHANGE THESE!)
ADMIN_USER=admin
ADMIN_PASS=changeme123!

# Site branding
SITE_NAME=ThreatLens
SITE_TAGLINE=CVE Intelligence for Threat Hunters

# Database (SQLite by default — no setup needed)
DATABASE_URL=sqlite:///./threat_intel.db

# ── AI Enrichment ──────────────────────────────────────────────────────────
# Provider: "ollama", "openai", "anthropic", or "mock"
AI_PROVIDER=ollama

# Ollama (free, local — no API key needed)
AI_MODEL_OLLAMA=mistral
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI (requires API key)
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
AI_MODEL_OPENAI=gpt-4o-mini

# Anthropic (requires API key)
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
AI_MODEL_ANTHROPIC=claude-haiku-4-5-20251001

# ── IOC Lookup (add keys for richer threat intelligence) ──────────────────
# AlienVault OTX — works without a key, but adding one raises rate limits
# Free signup: https://otx.alienvault.com/
OTX_API_KEY=

# VirusTotal — required for detection ratios, sandbox verdicts, engine results
# Free tier: 4 requests/min, 500/day — https://www.virustotal.com/gui/join-us
VT_API_KEY=

# AbuseIPDB — required for IP abuse confidence scores and reports
# Free tier: 1000 checks/day — https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# ── Crawler Settings ──────────────────────────────────────────────────────
CRAWL_INTERVAL_HOURS=6
NVD_DAYS_BACK=2

# NVD API key (free, gets you higher rate limits)
# Get one at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
